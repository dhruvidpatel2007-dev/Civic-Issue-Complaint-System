<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Registration - Civic Issue Complaint</title>
  <style>
    /* Reset default styles */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    body {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      background: linear-gradient(135deg, #6fb1fc, #4364f7);
    }

    .register-container {
      background: #fff;
      padding: 40px 30px;
      border-radius: 12px;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
      width: 360px;
      text-align: center;
    }

    .register-container h1 {
      margin-bottom: 25px;
      color: #333;
      font-size: 28px;
    }

    .register-container form {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .register-container input[type="text"],
    .register-container input[type="email"],
    .register-container input[type="password"] {
      padding: 12px 15px;
      border: 1px solid #ccc;
      border-radius: 8px;
      font-size: 16px;
      outline: none;
      transition: 0.3s;
    }

    .register-container input:focus {
      border-color: #4364f7;
      box-shadow: 0 0 5px rgba(67, 100, 247, 0.5);
    }

    .register-container button {
      padding: 12px;
      border: none;
      border-radius: 8px;
      background-color: #4364f7;
      color: #fff;
      font-size: 16px;
      cursor: pointer;
      transition: 0.3s;
    }

    .register-container button:hover {
      background-color: #6fb1fc;
    }

    .register-container .footer-links {
      margin-top: 10px;
      font-size: 14px;
    }

    .register-container .footer-links a {
      color: #4364f7;
      text-decoration: none;
      transition: 0.3s;
    }

    .register-container .footer-links a:hover {
      text-decoration: underline;
    }

    .register-container .footer {
      margin-top: 20px;
      font-size: 14px;
      color: #555;
    }
  </style>
</head>
<body>
  <div class="register-container">
    <h1>Admin Registration</h1>
    <form action="/register" method="POST">
      <input type="text" name="username" placeholder="Username" required>
      <input type="email" name="email" placeholder="Email" required>
      <input type="password" name="password" placeholder="Password" required>
      <input type="password" name="confirm_password" placeholder="Confirm Password" required>
      <button type="submit">Register</button>
    </form>

    <div class="footer-links">
      Already have an account? <a href="/login">Login here</a>
    </div>

    <div class="footer">
      © 2026 Civic Issue Complaint
    </div>
  </div>
</body>
</html>
{% with messages = get_flashed_messages(with_categories=true) %}
  {% if messages %}
    {% for category, message in messages %}
      <div class="flash {{ category }}">{{ message }}</div>
    {% endfor %}
  {% endif %}
{% endwith %}
